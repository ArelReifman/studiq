# Database (required for API — use Supabase → Settings → Database → connection string)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Rate-limit store (optional). When both are set, rate limits are shared across
# all serverless instances via Upstash Redis. When unset, the limiter falls
# back to a per-instance in-memory Map (fine for local dev / single instance).
# Get them from https://console.upstash.com → your Redis DB → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
